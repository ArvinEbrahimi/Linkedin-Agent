# Groq (required for /chat)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# LinkedIn OAuth (optional — see docs/LINKEDIN_SETUP.md)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/linkedin/auth/callback
UI_BASE_URL=http://localhost:8501
APP_SECRET_KEY=change-me-in-production

# Search (optional — falls back to DuckDuckGo)
TAVILY_API_KEY=

# Streamlit UI (optional)
LINKAID_API_URL=http://localhost:8000

# Observability (optional — pip install -e ".[observability]")
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# App
ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/linkaid.db
CHROMA_PERSIST_DIR=./data/chroma
CHECKPOINT_DB_PATH=./data/checkpoints.db
OUTREACH_LIMIT_DB_PATH=./data/outreach_limits.db
MAX_DAILY_OUTREACH=20
